---
import ConsoleShell from "../../components/ConsoleShell.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "dns.js.gripe 个人 DNS 控制台";
const description = "使用账户中心登录后管理 dquery 的个人 DNS profile、规则和 profile token。";
---

<BaseLayout
  title={title}
  description={description}
  lang="zh-CN"
  canonical="https://dns.js.gripe/console/"
  alternates={[{ lang: "zh-CN", href: "https://dns.js.gripe/console/" }]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "dns.js.gripe console",
    applicationCategory: "DeveloperApplication",
    operatingSystem: "Any",
    url: "https://dns.js.gripe/console/",
    description
  }}
>
  <main id="main" class="console-shell">
    <ConsoleShell />
  </main>
</BaseLayout>
