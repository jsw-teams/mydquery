---
import HelpContent from "../../../components/HelpContent.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const title = "Set up dns.js.gripe DoH";
const description = "Simple instructions for setting up dns.js.gripe DNS-over-HTTPS on Windows, Android, iPhone, and iPad.";
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  canonical="https://dns.js.gripe/en/help/"
  alternates={[
    { lang: "zh-CN", href: "https://dns.js.gripe/help/" },
    { lang: "en", href: "https://dns.js.gripe/en/help/" }
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "TechArticle",
    headline: title,
    url: "https://dns.js.gripe/en/help/",
    description
  }}
>
  <HelpContent lang="en" />
</BaseLayout>
