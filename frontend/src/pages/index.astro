---
import DnsLookup from "../components/DnsLookup.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "dquery.js.gripe 公共 DNS 查询";
const description = "使用 dquery.js.gripe 查询公共 DNS 记录，并以 DNS JSON 查看原始响应。";
---

<BaseLayout
  title={title}
  description={description}
  lang="zh-CN"
  canonical="https://dquery.js.gripe/"
  alternates={[
    { lang: "zh-CN", href: "https://dquery.js.gripe/" },
    { lang: "en", href: "https://dquery.js.gripe/en/" }
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "dquery.js.gripe",
    applicationCategory: "DeveloperApplication",
    operatingSystem: "Any",
    url: "https://dquery.js.gripe/",
    description
  }}
>
  <DnsLookup lang="zh-CN" />
</BaseLayout>
