---
import setupScript from "../scripts/setup-init.js?url";
---

<main class="login-page pixel-auth" id="main" data-i18n-scope="setup">
  <section class="login-card" aria-labelledby="setup-title">
    <div class="login-art">
      <img src="/media/dquery-login-pixel-v2.png" alt="" width="220" height="220" />
    </div>
    <div class="login-form-panel">
      <p class="pixel-kicker" data-i18n="kicker">dquery 初始化</p>
      <h1 id="setup-title" data-i18n="title">创建首个系统管理员</h1>
      <p class="login-copy" data-i18n="copy">初始化只允许在没有本地用户时执行。首个账户会成为 system_admin。</p>
      <form class="login-primary-action" id="setup-form">
        <label>
          <span data-i18n="email">邮箱</span>
          <input id="setup-email" type="email" autocomplete="username" required />
        </label>
        <label>
          <span data-i18n="displayName">显示名</span>
          <input id="setup-display-name" autocomplete="name" />
        </label>
        <label>
          <span data-i18n="password">密码</span>
          <input id="setup-password" type="password" autocomplete="new-password" minlength="10" required />
        </label>
        <button class="pixel-button" type="submit" data-i18n="submit">初始化</button>
      </form>
      <div class="pixel-alert" id="setup-status" role="status" aria-live="polite"></div>
    </div>
  </section>
</main>

<script src={setupScript}></script>
